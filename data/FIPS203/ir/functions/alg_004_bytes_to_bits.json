      "name": "b",
      "type": "bit_array",
      "description": "Converted bit array of length 8 * |B|"
    }
  ],
  "body_raw": [
    "C ← B",
    "for (i ← 0; i < ℓ; i ++)",
    "    for (j ← 0; j < 8; j ++)",
    "        b[8i + j] ← C[i] mod 2",
    "        C[i] ← ⌊C[i]/2⌋",
    "    end for",
    "end for",
    "return b"
  ],
