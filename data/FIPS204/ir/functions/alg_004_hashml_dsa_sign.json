{
  "function_id": "alg_004_hashml_dsa_sign",
  "name": "HashML-DSA.Sign",
  "label": "Algorithm 4",
  "page_start": 20,
  "page_end": 20,
  "inputs": [
    {
      "name": "sk",
      "type": "byte_array",
      "description": "private key"
    },
    {
      "name": "m",
      "type": "bit_array",
      "description": "message"
    },
    {
      "name": "ctx",
      "type": "byte_array",
      "description": "context string"
    },
    {
      "name": "ph",
      "type": "hash_function",
      "description": "pre-hash function"
    }
  ],
  "outputs": [
    {
      "name": "sigma",
      "type": "byte_array",
      "description": "signature"
    }
  ],
  "body_raw": [
    "if |ctx| > 255 then",
    "return failure",
    "end if",
    "rnd <- B^32",
    "if rnd = NULL then",
    "return failure",
    "end if",
    "switch PH do",
    "case SHA-256:",
    "OID <- 0x06, 0x09, 0x60, 0x86, 0x48, 0x01, 0x65, 0x03, 0x04, 0x02, 0x01",
    "PHM <- SHA256(M)",
    "case SHA-512:",
    "OID <- 0x06, 0x09, 0x60, 0x86, 0x48, 0x01, 0x65, 0x03, 0x04, 0x02, 0x03",
    "PHM <- SHA512(M)",
    "case SHAKE128:",
    "OID <- 0x06, 0x09, 0x60, 0x86, 0x48, 0x01, 0x65, 0x03, 0x04, 0x02, 0x0B",
    "PHM <- SHAKE128(M, 256)",
    "case ...",
    "...",
    "end switch",
    "M_prime <- BytesToBits(IntegerToBytes(1, 1) || IntegerToBytes(|ctx|, 1) || ctx || OID || PHM)",
    "sigma <- ML-DSA.Sign_internal(sk, M_prime, rnd)",
    "return sigma"
  ]
}