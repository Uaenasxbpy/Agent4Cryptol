  "body_raw": [
    "c <- bitlen(a + b)",
    "z <- BytesToBits(v)",
    "for i from 0 to 255 do",
    "    w_i <- b - BitsToInteger((z[i*c], ..., z[i*c + c - 1]), c)",
    "end for",
    "return w"
