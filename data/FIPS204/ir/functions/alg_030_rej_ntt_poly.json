  "body_raw": [
    "j <- 0",
    "ctx <- G.Init()",
    "ctx <- G.Absorb(ctx, rho)",
    "while j < 256 do",
    "    (ctx, s) <- G.Squeeze(ctx, 3)",
    "    a_hat[j] <- CoeffFromThreeBytes(s[0], s[1], s[2])",
    "    if a_hat[j] != bottom then j <- j + 1",
    "end while",
    "return a_hat"
