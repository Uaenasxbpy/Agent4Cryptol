{
  "function_id": "alg_030_rej_ntt_poly",
  "name": "RejNTTPoly",
  "label": "Algorithm 30",
  "page_start": 37,
  "page_end": 37,
  "inputs": [
    {
      "name": "rho",
      "type": "byte_array",
      "description": "seed"
    }
  ],
  "outputs": [
    {
      "name": "a_hat",
      "type": "ntt_poly",
      "description": "sampled NTT polynomial"
    }
  ],
  "body_raw": [
    "j <- 0",
    "ctx <- G.Init()",
    "ctx <- G.Absorb(ctx, rho)",
    "while j < 256 do",
    "(ctx, s) <- G.Squeeze(ctx, 3)",
    "a_hat[j] <- CoeffFromThreeBytes(s[0], s[1], s[2])",
    "if a_hat[j] != failure then",
    "j <- j + 1",
    "end if",
    "end while",
    "return a_hat"
  ]
}