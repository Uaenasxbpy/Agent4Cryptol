  "body_raw": [
    "𝑚 ← (𝑞 − 1)/(2𝛾2)",
    "(𝑟1, 𝑟0) ← Decompose(𝑟)",
    "if ℎ = 1 and 𝑟0 > 0 return (𝑟1 + 1) mod 𝑚",
    "if ℎ = 1 and 𝑟0 ≤ 0 return (𝑟1 − 1) mod 𝑚",
    "return 𝑟1"
  ]
