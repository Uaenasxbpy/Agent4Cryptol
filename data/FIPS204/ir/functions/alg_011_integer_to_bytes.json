{
  "function_id": "alg_011_integer_to_bytes",
  "name": "IntegerToBytes",
  "label": "Algorithm 11",
  "page_start": 28,
  "page_end": 28,
  "inputs": [
    {
      "name": "x",
      "type": "int",
      "description": "nonnegative integer"
    },
    {
      "name": "alpha",
      "type": "int",
      "description": "byte length"
    }
  ],
  "outputs": [
    {
      "name": "y",
      "type": "byte_array",
      "description": "byte string"
    }
  ],
  "body_raw": [
    "𝑥′ ← 𝑥",
    "for 𝑖 from 0 to 𝛼 − 1 do",
    "𝑦[𝑖] ← 𝑥 ′ mod",
    "𝑥 ′ ← ⌊𝑥 ′ /256⌋",
    "end for",
    "return 𝑦"
  ]
}