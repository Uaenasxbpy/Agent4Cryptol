  "body_raw": [
    "y <- zero_bytes(omega + k)",
    "Index <- 0",
    "for i from 0 to k - 1 do",
    "    for j from 0 to 255 do",
    "        if h[i]_j != 0 then y[Index] <- j; Index <- Index + 1",
    "    end for",
    "    y[omega + i] <- Index",
    "end for",
    "return y"
  ],
