{
  "function_id": "alg_009_integer_to_bits",
  "name": "IntegerToBits",
  "label": "Algorithm 9",
  "page_start": 28,
  "page_end": 28,
  "inputs": [
    {
      "name": "x",
      "type": "int",
      "description": "nonnegative integer"
    },
    {
      "name": "alpha",
      "type": "int",
      "description": "bit length"
    }
  ],
  "outputs": [
    {
      "name": "y",
      "type": "bit_array",
      "description": "bit string"
    }
  ],
  "body_raw": [
    "𝑥 ′ ← 𝑥",
    "for 𝑖 from 0 to 𝛼 − 1 do",
    "𝑦[𝑖] ← 𝑥 ′ mod 2",
    "𝑥 ′ ← ⌊𝑥 ′ /2⌋",
    "end for",
    "return 𝑦"
  ]
}