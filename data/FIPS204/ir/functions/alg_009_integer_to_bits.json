  "function_id": "alg_009_integer_to_bits",
  "name": "IntegerToBits",
  "label": "Algorithm 9",
  "page_start": 28,
  "page_end": 28,
  "inputs": [
    {
      "name": "x",
      "type": "int",
      "description": "Nonnegative integer"
    },
    {
      "name": "alpha",
      "type": "int",
      "description": "Positive length"
    }
  ],
  "outputs": [
    {
      "name": "y",
      "type": "bit_array",
      "description": "Bit string of length alpha"
    }
  ],
  "body_raw": [
    "x_prime <- x",
    "for i from 0 to alpha - 1 do",
    "    y[i] <- x_prime mod 2",
    "    x_prime <- floor(x_prime / 2)",
    "end for",
    "return y"
  ],
