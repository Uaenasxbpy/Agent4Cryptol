{
  "function_id": "alg_007_ml_dsa_sign_internal",
  "name": "ML-DSA.Sign_internal",
  "label": "Algorithm 7",
  "page_start": 25,
  "page_end": 25,
  "inputs": [
    {
      "name": "sk",
      "type": "byte_array",
      "description": "Private key"
    },
    {
      "name": "M_prime",
      "type": "bit_string",
      "description": "Formatted message"
    },
    {
      "name": "rnd",
      "type": "byte_array",
      "description": "32-byte per-message randomness or zero string"
    }
  ],
  "outputs": [
    {
      "name": "sigma",
      "type": "byte_array",
      "description": "Signature byte string"
    }
  ],
  "body_raw": [
    "(rho, K, tr, s1, s2, t0) <- skDecode(sk)",
    "s1_hat <- NTT(s1); s2_hat <- NTT(s2); t0_hat <- NTT(t0)",
    "A_hat <- ExpandA(rho)",
    "mu <- H(BytesToBits(tr) || M_prime, 64)",
    "rho_dblprime <- H(K || rnd || mu, 64)",
    "kappa <- 0",
    "while (z, h) == bottom do",
    "    y <- ExpandMask(rho_dblprime, kappa)",
    "    w <- NTT_inverse(A_hat ∘ NTT(y))",
    "    w1 <- HighBits(w)",
    "    c_tilde <- H(mu || w1Encode(w1), lambda/4)",
    "    c <- SampleInBall(c_tilde)",
    "    c_hat <- NTT(c)",
    "    c_s1 <- NTT_inverse(c_hat ∘ s1_hat)",
    "    c_s2 <- NTT_inverse(c_hat ∘ s2_hat)",
    "    z <- y + c_s1",
    "    r0 <- LowBits(w - c_s2)",
    "    if ||z||_inf >= gamma1 - beta or ||r0||_inf >= gamma2 - beta then (z,h) <- bottom",
    "    else",
    "        c_t0 <- NTT_inverse(c_hat ∘ t0_hat)",
    "        h <- MakeHint(-c_t0, w - c_s2 + c_t0)",
    "        if ||c_t0||_inf >= gamma2 or number_of_ones(h) > omega then (z,h) <- bottom",
    "    end if",
    "    kappa <- kappa + l",
    "end while",
    "sigma <- sigEncode(c_tilde, z modpm q, h)",
    "return sigma"
  ],
