  "function_id": "alg_036_decompose",
  "name": "Decompose",
  "label": "Algorithm 36",
  "page_start": 40,
  "page_end": 40,
  "inputs": [
    {
      "name": "r",
      "type": "int_mod_q",
      "description": "Input coefficient modulo q"
    }
  ],
  "outputs": [
    {
      "name": "r1",
      "type": "int",
      "description": "High component"
    },
    {
      "name": "r0",
      "type": "int",
      "description": "Low component"
    }
  ],
  "body_raw": [
    "r_plus <- r mod q",
    "r0 <- r_plus modpm (2*gamma2)",
    "if r_plus - r0 == q - 1 then",
    "    r1 <- 0",
    "    r0 <- r0 - 1",
    "else",
    "    r1 <- (r_plus - r0)/(2*gamma2)",
    "end if",
    "return (r1, r0)"
  ],
