  "body_raw": [
    "j <- 0",
    "ctx <- H.Init()",
    "ctx <- H.Absorb(ctx, rho)",
    "while j < 256 do",
    "    z <- H.Squeeze(ctx, 1)",
    "    z0 <- CoeffFromHalfByte(z mod 16)",
    "    z1 <- CoeffFromHalfByte(floor(z / 16))",
    "    if z0 != bottom then a_j <- z0; j <- j + 1",
    "    if z1 != bottom and j < 256 then a_j <- z1; j <- j + 1",
    "end while",
    "return a"
  ],
