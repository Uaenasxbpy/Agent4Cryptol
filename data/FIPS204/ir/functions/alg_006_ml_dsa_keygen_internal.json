  "outputs": [
    {
      "name": "pk",
      "type": "byte_array",
      "description": "Public key"
    },
    {
      "name": "sk",
      "type": "byte_array",
      "description": "Private key"
    }
  ],
  "body_raw": [
    "(rho, rho_prime, K) <- H(xi || IntegerToBytes(k,1) || IntegerToBytes(l,1), 128)",
    "A_hat <- ExpandA(rho)",
    "(s1, s2) <- ExpandS(rho_prime)",
    "t <- NTT_inverse(A_hat ∘ NTT(s1)) + s2",
    "(t1, t0) <- Power2Round(t)",
    "pk <- pkEncode(rho, t1)",
    "tr <- H(pk, 64)",
    "sk <- skEncode(rho, K, tr, s1, s2, t0)",
    "return (pk, sk)"
  ],
