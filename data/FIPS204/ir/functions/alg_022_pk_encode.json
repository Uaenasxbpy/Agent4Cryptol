  "body_raw": [
    "𝑝𝑘 ← 𝜌",
    "for 𝑖 from 0 to 𝑘 − 1 do",
    "𝑝𝑘 ← 𝑝𝑘 || SimpleBitPack (𝐭1[𝑖], 2bitlen (𝑞−1)−𝑑 − 1)",
    "end for",
    "return 𝑝𝑘"
  ]
}