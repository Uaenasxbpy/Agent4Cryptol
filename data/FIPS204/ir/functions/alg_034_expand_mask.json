  "body_raw": [
    "c <- 1 + bitlen(gamma1 - 1)",
    "for r from 0 to l - 1 do",
    "    rho_prime <- rho || IntegerToBytes(mu + r, 2)",
    "    v <- H(rho_prime, 32*c)",
    "    y[r] <- BitUnpack(v, gamma1 - 1, gamma1)",
    "end for",
    "return y"
  ],
