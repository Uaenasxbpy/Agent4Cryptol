{
  "function_id": "alg_008_ml_dsa_verify_internal",
  "name": "ML-DSA.Verify_internal",
  "label": "Algorithm 8",
  "page_start": 27,
  "page_end": 27,
  "inputs": [
    {
      "name": "pk",
      "type": "byte_array",
      "description": "Public key"
    },
    {
      "name": "M_prime",
      "type": "bit_string",
      "description": "Formatted message"
    },
    {
      "name": "sigma",
      "type": "byte_array",
      "description": "Signature"
    }
  ],
  "outputs": [
    {
      "name": "ok",
      "type": "bool",
      "description": "Verification result"
    }
  ],
  "body_raw": [
    "(rho, t1) <- pkDecode(pk)",
    "(c_tilde, z, h) <- sigDecode(sigma)",
    "if h == bottom then return false",
    "A_hat <- ExpandA(rho)",
    "tr <- H(pk, 64)",
    "mu <- H(BytesToBits(tr) || M_prime, 64)",
    "c <- SampleInBall(c_tilde)",
    "w_approx <- NTT_inverse(A_hat ∘ NTT(z) - NTT(c) ∘ NTT(t1 * 2^d))",
    "w1_prime <- UseHint(h, w_approx)",
    "c_tilde_prime <- H(mu || w1Encode(w1_prime), lambda/4)",
    "return [[ ||z||_inf < gamma1 - beta ]] and [[ c_tilde == c_tilde_prime ]]"
  ],
