      "description": "Bit string"
    }
  ],
  "outputs": [
    {
      "name": "z",
      "type": "byte_array",
      "description": "Byte string of length ceil(alpha/8)"
    }
  ],
  "body_raw": [
    "z <- zero_bytes(ceil(alpha/8))",
    "for i from 0 to alpha - 1 do",
    "    z[floor(i/8)] <- z[floor(i/8)] + y[i] * 2^(i mod 8)",
    "end for",
    "return z"
  ],
