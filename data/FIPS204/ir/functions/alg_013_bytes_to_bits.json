  "function_id": "alg_013_bytes_to_bits",
  "name": "BytesToBits",
  "label": "Algorithm 13",
  "page_start": 29,
  "page_end": 29,
  "inputs": [
    {
      "name": "z",
      "type": "byte_array",
      "description": "Byte string"
    }
  ],
  "outputs": [
    {
      "name": "y",
      "type": "bit_array",
      "description": "Bit string of length 8*alpha"
    }
  ],
  "body_raw": [
    "z_prime <- z",
    "for i from 0 to alpha - 1 do",
    "    for j from 0 to 7 do",
    "        y[8*i + j] <- z_prime[i] mod 2",
    "        z_prime[i] <- floor(z_prime[i] / 2)",
    "    end for",
    "end for",
    "return y"
  ],
