  "outputs": [
    {
      "name": "sigma",
      "type": "byte_array",
      "description": "Signature byte string or bottom"
    }
  ],
  "body_raw": [
    "if |ctx| > 255 then return bottom",
    "rnd <- random B^32  // deterministic variant uses {0}^32",
    "if rnd == NULL then return bottom",
    "M_prime <- BytesToBits(IntegerToBytes(0,1) || IntegerToBytes(|ctx|,1) || ctx) || M",
    "sigma <- ML-DSA.Sign_internal(sk, M_prime, rnd)",
    "return sigma"
  ],
