  "body_raw": [
    "𝐰̃1 ← ()",
    "for 𝑖 from 0 to 𝑘 − 1 do",
    "𝐰̃1 ← 𝐰̃1 || SimpleBitPack (𝐰1[𝑖], (𝑞 − 1)/(2𝛾2) − 1)",
    "end for",
    "return 𝐰̃ 1"
