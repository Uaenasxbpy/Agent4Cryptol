  "body_raw": [
    "SIG_FORS <- NULL",
    "indices <- base_2b(md, a, k)",
    "for i from 0 to k - 1 do",
    "    SIG_FORS <- SIG_FORS || fors_skGen(SK.seed, PK.seed, ADRS, i * 2^a + indices[i])",
    "    for j from 0 to a - 1 do",
    "        s <- floor(indices[i] / 2^j) xor 1",
    "        AUTH[j] <- fors_node(SK.seed, i * 2^(a - j) + s, j, PK.seed, ADRS)",
    "    end for",
    "    SIG_FORS <- SIG_FORS || AUTH",
    "end for",
    "return SIG_FORS"
  ],
