  "outputs": [
    {
      "name": "SIG",
      "type": "byte_array",
      "description": "Pre-hash SLH-DSA signature"
    }
  ],
  "body_raw": [
    "if |ctx| > 255 then return bottom",
    "addrnd <- random B^n  // omit for deterministic variant",
    "if addrnd == NULL then return bottom",
    "switch PH do",
    "    case SHA-256: OID <- 0x0609608648016503040201; PHM <- SHA-256(M)",
    "    case SHA-512: OID <- 0x0609608648016503040203; PHM <- SHA-512(M)",
    "    case SHAKE128: OID <- 0x060960864801650304020B; PHM <- SHAKE128(M, 256)",
    "    case SHAKE256: OID <- 0x060960864801650304020C; PHM <- SHAKE256(M, 512)",
    "    case ...",
    "end switch",
    "M_prime <- toByte(1, 1) || toByte(|ctx|, 1) || ctx || OID || PHM",
    "SIG <- slh_sign_internal(M_prime, SK, addrnd)",
    "return SIG"
  ],
