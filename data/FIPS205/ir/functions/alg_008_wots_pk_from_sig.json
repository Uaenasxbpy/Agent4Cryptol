    },
    {
      "name": "PK.seed",
      "type": "byte_array",
      "description": "Public seed"
    },
    {
      "name": "ADRS",
      "type": "address",
      "description": "WOTS+ address"
    }
  ],
  "outputs": [
    {
      "name": "pksig",
      "type": "byte_array",
      "description": "Derived WOTS+ public key"
    }
  ],
  "body_raw": [
    "csum <- 0",
    "msg <- base_2b(M, lgw, len1)",
    "for i from 0 to len1 - 1 do",
    "    csum <- csum + w - 1 - msg[i]",
    "end for",
    "csum <- csum << ((8 - ((len2 * lgw) mod 8)) mod 8)",
    "msg <- msg || base_2b(toByte(csum, ceil(len2 * lgw / 8)), lgw, len2)",
    "for i from 0 to len - 1 do",
    "    ADRS.setChainAddress(i)",
    "    tmp[i] <- chain(sig[i], msg[i], w - 1 - msg[i], PK.seed, ADRS)",
    "end for",
    "wotspkADRS <- ADRS",
    "wotspkADRS.setTypeAndClear(WOTS_PK)",
    "wotspkADRS.setKeyPairAddress(ADRS.getKeyPairAddress())",
    "pksig <- T_len(PK.seed, wotspkADRS, tmp)",
    "return pksig"
  ],
