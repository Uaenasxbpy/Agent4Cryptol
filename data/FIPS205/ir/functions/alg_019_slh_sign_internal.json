      "description": "Private key tuple (SK.seed, SK.prf, PK.seed, PK.root)"
    },
    {
      "name": "addrnd",
      "type": "byte_array",
      "description": "Optional additional randomness"
    }
  ],
  "outputs": [
    {
      "name": "SIG",
      "type": "byte_array",
      "description": "SLH-DSA signature"
    }
  ],
  "body_raw": [
    "ADRS <- toByte(0, 32)",
    "opt_rand <- addrnd  // deterministic variant uses PK.seed",
    "R <- PRFmsg(SK.prf, opt_rand, M)",
    "SIG <- R",
    "digest <- Hmsg(R, PK.seed, PK.root, M)",
    "md <- digest[0 : ceil(k * a / 8)]",
    "tmp_idx_tree <- digest[ceil(k * a / 8) : ceil(k * a / 8) + ceil((h - h / d) / 8)]",
    "tmp_idx_leaf <- digest[ceil(k * a / 8) + ceil((h - h / d) / 8) : ceil(k * a / 8) + ceil((h - h / d) / 8) + ceil((h / d) / 8)]",
    "idx_tree <- toInt(tmp_idx_tree, ceil((h - h / d) / 8)) mod 2^(h - h / d)",
    "idx_leaf <- toInt(tmp_idx_leaf, ceil((h / d) / 8)) mod 2^(h / d)",
    "ADRS.setTreeAddress(idx_tree)",
    "ADRS.setTypeAndClear(FORS_TREE)",
    "ADRS.setKeyPairAddress(idx_leaf)",
    "SIG_FORS <- fors_sign(md, SK.seed, PK.seed, ADRS)",
    "SIG <- SIG || SIG_FORS",
    "PK_FORS <- fors_pkFromSig(SIG_FORS, md, PK.seed, ADRS)",
    "SIG_HT <- ht_sign(PK_FORS, SK.seed, PK.seed, idx_tree, idx_leaf)",
    "SIG <- SIG || SIG_HT",
    "return SIG"
  ],
