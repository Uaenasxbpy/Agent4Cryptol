  "body_raw": [
    "if z = 0 then",
    "    sk <- fors_skGen(SK.seed, PK.seed, ADRS, i)",
    "    ADRS.setTreeHeight(0)",
    "    ADRS.setTreeIndex(i)",
    "    node <- F(PK.seed, ADRS, sk)",
    "else",
    "    lnode <- fors_node(SK.seed, 2*i, z - 1, PK.seed, ADRS)",
    "    rnode <- fors_node(SK.seed, 2*i + 1, z - 1, PK.seed, ADRS)",
    "    ADRS.setTreeHeight(z)",
    "    ADRS.setTreeIndex(i)",
    "    node <- H(PK.seed, ADRS, lnode || rnode)",
    "end if",
    "return node"
  ],
