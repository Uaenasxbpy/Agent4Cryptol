  "function_id": "alg_003_to_byte",
  "name": "toByte",
  "label": "Algorithm 3",
  "page_start": 25,
  "page_end": 25,
  "inputs": [
    {
      "name": "x",
      "type": "int",
      "description": "Input integer"
    },
    {
      "name": "n",
      "type": "int",
      "description": "Target byte-string length"
    }
  ],
  "outputs": [
    {
      "name": "S",
      "type": "byte_array",
      "description": "Big-endian byte string"
    }
  ],
  "body_raw": [
    "total <- x",
    "for i from 0 to n - 1 do",
    "    S[n - 1 - i] <- total mod 256",
    "    total <- total >> 8",
    "end for",
    "return S"
  ],
