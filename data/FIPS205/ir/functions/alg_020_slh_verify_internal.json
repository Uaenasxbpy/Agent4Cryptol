  "body_raw": [
    "if |SIG| != (1 + k * (1 + a) + h + d * len) * n then return false",
    "ADRS <- toByte(0, 32)",
    "R <- SIG.getR()",
    "SIG_FORS <- SIG.getSIG_FORS()",
    "SIG_HT <- SIG.getSIG_HT()",
    "digest <- Hmsg(R, PK.seed, PK.root, M)",
    "md <- digest[0 : ceil(k * a / 8)]",
    "tmp_idx_tree <- digest[ceil(k * a / 8) : ceil(k * a / 8) + ceil((h - h / d) / 8)]",
    "tmp_idx_leaf <- digest[ceil(k * a / 8) + ceil((h - h / d) / 8) : ceil(k * a / 8) + ceil((h - h / d) / 8) + ceil((h / d) / 8)]",
    "idx_tree <- toInt(tmp_idx_tree, ceil((h - h / d) / 8)) mod 2^(h - h / d)",
    "idx_leaf <- toInt(tmp_idx_leaf, ceil((h / d) / 8)) mod 2^(h / d)",
    "ADRS.setTreeAddress(idx_tree)",
    "ADRS.setTypeAndClear(FORS_TREE)",
    "ADRS.setKeyPairAddress(idx_leaf)",
    "PK_FORS <- fors_pkFromSig(SIG_FORS, md, PK.seed, ADRS)",
    "return ht_verify(PK_FORS, SIG_HT, PK.seed, idx_tree, idx_leaf, PK.root)"
  ],
