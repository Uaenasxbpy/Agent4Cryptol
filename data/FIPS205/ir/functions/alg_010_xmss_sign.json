  "body_raw": [
    "for j from 0 to h_prime - 1 do",
    "    k <- floor(idx / 2^j) xor 1",
    "    AUTH[j] <- xmss_node(SK.seed, k, j, PK.seed, ADRS)",
    "end for",
    "ADRS.setTypeAndClear(WOTS_HASH)",
    "ADRS.setKeyPairAddress(idx)",
    "sig <- wots_sign(M, SK.seed, PK.seed, ADRS)",
    "SIG_XMSS <- sig || AUTH",
    "return SIG_XMSS"
  ],
