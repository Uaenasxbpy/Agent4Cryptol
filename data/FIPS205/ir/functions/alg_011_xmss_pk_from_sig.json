      "description": "Candidate XMSS public key"
    }
  ],
  "body_raw": [
    "ADRS.setTypeAndClear(WOTS_HASH)",
    "ADRS.setKeyPairAddress(idx)",
    "sig <- SIG_XMSS.getWOTSSig()",
    "AUTH <- SIG_XMSS.getXMSSAUTH()",
    "node[0] <- wots_pkFromSig(sig, M, PK.seed, ADRS)",
    "ADRS.setTypeAndClear(TREE)",
    "ADRS.setTreeIndex(idx)",
    "for k from 0 to h_prime - 1 do",
    "    ADRS.setTreeHeight(k + 1)",
    "    if floor(idx / 2^k) is even then",
    "        ADRS.setTreeIndex(ADRS.getTreeIndex() / 2)",
    "        node[1] <- H(PK.seed, ADRS, node[0] || AUTH[k])",
    "    else",
    "        ADRS.setTreeIndex((ADRS.getTreeIndex() - 1) / 2)",
    "        node[1] <- H(PK.seed, ADRS, AUTH[k] || node[0])",
    "    end if",
    "    node[0] <- node[1]",
    "end for",
    "return node[0]"
  ],
