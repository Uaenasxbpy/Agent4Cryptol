{
  "function_id": "alg_001_gen_len2",
  "name": "gen_len2",
  "label": "Algorithm 1",
  "page_start": 20,
  "page_end": 20,
  "inputs": [
    {
      "name": "n",
      "type": "int",
      "description": "Security parameter in bytes"
    },
    {
      "name": "lgw",
      "type": "int",
      "description": "Bits per hash chain"
    }
  ],
  "outputs": [
    {
      "name": "len2",
      "type": "int",
      "description": "Checksum chain count"
    }
  ],
  "body_raw": [
    "w <- 2^lgw",
    "len1 <- floor((8 * n + lgw - 1) / lgw)",
    "max_checksum <- len1 * (w - 1)",
    "len2 <- 1",
    "capacity <- w",
    "while capacity <= max_checksum do",
    "    len2 <- len2 + 1",
    "    capacity <- capacity * w",
    "end while",
    "return len2"
  ],
