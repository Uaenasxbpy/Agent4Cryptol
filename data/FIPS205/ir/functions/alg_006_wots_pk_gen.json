{
  "function_id": "alg_006_wots_pk_gen",
  "name": "wots_pkGen(SK.seed, PK.seed, ADRS)",
  "label": "Algorithm 6",
  "page_start": 18,
  "page_end": 18,
  "inputs": [
    {
      "name": "SK_seed",
      "type": "byte_array",
      "description": "secret seed"
    },
    {
      "name": "PK_seed",
      "type": "byte_array",
      "description": "public seed"
    },
    {
      "name": "ADRS",
      "type": "byte_array",
      "description": "address of WOTS+ key"
    }
  ],
  "outputs": [
    {
      "name": "pk",
      "type": "byte_array",
      "description": "WOTS+ public key"
    }
  ],
  "body_raw": [
    "skADRS ← ADRS",
    "skADRS.setTypeAndClear(WOTS_PRF)",
    "skADRS.setKeyPairAddress(ADRS.getKeyPairAddress())",
    "for i from 0 to len - 1 do",
    "  skADRS.setChainAddress(i)",
    "  sk ← PRF(PK.seed, SK.seed, skADRS)",
    "  ADRS.setChainAddress(i)",
    "  tmp[i] ← chain(sk, 0, w - 1, PK.seed, ADRS)",
    "end for",
    "wotspkADRS ← ADRS",
    "wotspkADRS.setTypeAndClear(WOTS_PK)",
    "wotspkADRS.setKeyPairAddress(ADRS.getKeyPairAddress())",
    "pk ← T_len(PK.seed, wotspkADRS, tmp)",
    "return pk"
  ]
}