{
  "function_id": "alg_004_base_2b",
  "name": "base_2b",
  "label": "Algorithm 4",
  "page_start": 26,
  "page_end": 26,
  "inputs": [
    {
      "name": "X",
      "type": "byte_array",
      "description": "Input byte string"
    },
    {
      "name": "b",
      "type": "int",
      "description": "Digits are in base 2^b"
    },
    {
      "name": "out_len",
      "type": "int",
      "description": "Number of output digits"
    }
  ],
  "outputs": [
    {
      "name": "baseb",
      "type": "int_array",
      "description": "Array of out_len integers in [0, 2^b - 1]"
    }
  ],
  "body_raw": [
    "in <- 0",
    "bits <- 0",
    "total <- 0",
    "for out from 0 to out_len - 1 do",
    "    while bits < b do",
    "        total <- (total << 8) + X[in]",
    "        in <- in + 1",
    "        bits <- bits + 8",
    "    end while",
    "    bits <- bits - b",
    "    baseb[out] <- (total >> bits) mod 2^b",
    "end for",
    "return baseb"
  ],
