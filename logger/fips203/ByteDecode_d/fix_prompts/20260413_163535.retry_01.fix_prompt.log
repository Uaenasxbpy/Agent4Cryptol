==== 当前代码 ====
```cryptol
module ByteDecode_d where

// ASSUMPTION: d is a type-level parameter; m = 2^d if d < 12, else m = 3329 (q)
// Input B has length 32*d bytes = 256*d bits

ByteDecode_d : {d} (fin d, d >= 1) => [32*d][8] -> [256]Integer
ByteDecode_d B = F
  where
    // Convert byte array to bit array (big-endian per byte)
    bits : [256*d]
    bits = join [ reverse b | b <- B ]  // MSB first within each byte

    // Compute modulus m
    m : Integer
    m = if `d < 12 then 2^^(`d) else 3329

    // Reconstruct each integer from d bits
    F : [256]Integer
    F = [ sum [ zext (bits @ (i * `d + j)) * (2^^j) | j <- [0 .. (d-1)] ] % m
        | i <- [0 .. 255]
        ]
```

