// [Pattern] Ensure consistent bitvector widths with zero-extension
// Intent: Fix type mismatch errors from mixing bitvector widths.
// Template:
wider : [9]
wider = zext narrowVal  // narrowVal : [7]

wider2 : [9]
wider2 = (zero : [2]) # narrowVal
// Example:
len : [9]
len = zext (2 ^^ (layer + 1) : [8])

// [Pattern] Separate index-domain helpers from arithmetic-domain helpers
// Intent: Keep array indexing and arithmetic/modular computation in clearly separated domains, with explicit conversion points.
// Template:
idxStep : IDX -> IDX
idxStep i = ...

termValue : WORD -> Integer
termValue w = ...

result = arr @ idx
  where
    idx = idxStep base
// Example:
idx2 = idx1 + len
acc = (termA + termB) % modulus

// [Pattern] Backtick demotion: when and where to use `n to convert types to values
// Intent: Correctly use backtick notation to convert type parameters to runtime values.
// Template:
// CORRECT: `n in value expressions
f : {n} (fin n, Literal n Integer) => [n][8] -> Integer
f xs = `n

// CORRECT: `n in arithmetic
g : {n} (fin n, n >= 1) => [n][8] -> [8]
g xs = xs @ (`n - 1)

// WRONG: `n in enumeration bounds
// h = [0 .. `n - 1]   // parse error!
