// [Pattern] Use type-level arithmetic in finite sequence enumeration bounds
// Intent: Generate finite sequences whose length depends on a type parameter, using only type-level expressions in the bounds.
// Template:
// CORRECT: type-level bounds (no backtick)
f : {n} (fin n, n >= 1) => [n][8]
f = [ zero | i <- [0 .. (n-1)] ]

// CORRECT: take from infinite enumeration
g : {n} (fin n, n >= 1) => [n]Integer
g = take`{n} [0 ...]

// CORRECT: use the result type to drive length
h : {n} (fin n) => [n]Integer
h = [0 ...]
// Example:
indices : {n} (fin n, n >= 1) => [n]Integer
indices = take`{n} [0 ...]

ranged : {n} (fin n, n >= 1) => [n][8]
ranged = [0 .. (n-1)]

// [Pattern] Separate index-domain helpers from arithmetic-domain helpers
// Intent: Keep array indexing and arithmetic/modular computation in clearly separated domains, with explicit conversion points.
// Template:
idxStep : IDX -> IDX
idxStep i = ...

termValue : WORD -> Integer
termValue w = ...

result = arr @ idx
  where
    idx = idxStep base
// Example:
idx2 = idx1 + len
acc = (termA + termB) % modulus

// [Pattern] Ensure consistent bitvector widths with zero-extension
// Intent: Fix type mismatch errors from mixing bitvector widths.
// Template:
wider : [9]
wider = zext narrowVal  // narrowVal : [7]

wider2 : [9]
wider2 = (zero : [2]) # narrowVal
// Example:
len : [9]
len = zext (2 ^^ (layer + 1) : [8])

// [Pattern] Thread heterogeneous loop state with a tuple or record accumulator
// Intent: Model loop state that mixes arrays, counters, and flags by threading a tuple or record accumulator through recursion or foldl.
// Template:
step : (STATE_A, STATE_B) -> STEP_INPUT -> (STATE_A, STATE_B)
step (a, b) x = (a', b')
  where
    a' = ...
    b' = ...

result = foldl step initState inputs
// Example:
processLayer : ([256][12], [8]) -> [8] -> ([256][12], [8])
processLayer (f_hat, zetaIdx) layer = (f_hat', zetaIdx')

// [Pattern] Treat words as sequences of bits and reuse sequence operators
// Intent: Reuse generic sequence operators on words because `[n]` is just `[n]Bit`.
// Template:
hi = take`{k} w
lo = drop`{k} w
parts = split w
// Example:
take`{3} 0xFF
drop`{3} (12:[6])
split`{3} (12:[6])


