==== 当前代码 ====
```cryptol
module ByteEncode_d where

// ASSUMPTION: d is resolved from caller context to either du=10 or dv=4 per FIPS203.
// Since the function name includes "_d", and d is not an explicit input,
// we parameterize over d as a type-level constant, consistent with output length 32*d.

ByteEncode_d : {d} (fin d, d >= 1) => [256]Integer -> [32*d][8]
ByteEncode_d F = BitsToBytes bits
  where
    // Extract d bits from each of the 256 integers
    bits : [256*d]
    bits = [ bit | i <- [0 .. 255], j <- [0 .. (d-1)], let a0 = F@i, let bit = extractBit a0 j ]

    // Extract the j-th bit (LSB first) of integer a
    extractBit : Integer -> Integer -> Bit
    extractBit a j = if (a / (2^j)) % 2 == 1 then 1 else 0

    // Convert bit array of length 8*k to byte array of length k
    BitsToBytes : {k} (fin k) => [8*k] -> [k][8]
    BitsToBytes bs = [ join (reverse (split chunk)) | chunk <- split bs ]
      where
        split : [8*k] -> [k][8]
        split xs = groupBy`{8} xs

// Note: groupBy is a standard Cryptol primitive that groups a sequence into chunks of given size.
```

