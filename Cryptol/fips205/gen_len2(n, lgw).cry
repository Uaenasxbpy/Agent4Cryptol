module GenLen2 where

// lgw is a global constant = 4 for all approved SLH-DSA parameter sets
lgw : Integer
lgw = 4

// w = 2^lgw = 16
w : Integer
w = 16

genLen2 : Integer -> Integer
genLen2 n = len2
  where
    len1 = (8 * n + lgw - 1) / lgw
    maxChecksum = len1 * (w - 1)
    len2 = findLen2 1 w
    findLen2 : Integer -> Integer -> Integer
    findLen2 len2 capacity =
      if capacity <= maxChecksum
      then findLen2 (len2 + 1) (capacity * w)
      else len2