module BaseCaseMultiply where

// Global modulus q = 3329 from FIPS203 global_constants
q : Integer
q = 3329

BaseCaseMultiply : (Integer, Integer, Integer, Integer, Integer) -> (Integer, Integer)
BaseCaseMultiply (a0, a1, b0, b1, gamma) = (c0, c1)
  where
    c0 = (a0 * b0 + a1 * b1 * gamma) % q
    c1 = (a0 * b1 + a1 * b0) % q