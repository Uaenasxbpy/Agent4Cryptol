module NTT_inverse where

// Kyber modulus
q : [16]
q = 3329

// Scaling factor n^-1 mod q (256^-1 mod 3329)
scale : [16]
scale = 3303

// Bit reversal for 7-bit index (0..127)
bitRev7 : [7] -> [7]
bitRev7 x = join (reverse (split x))

// Modular arithmetic
modAdd : [16] -> [16] -> [16]
modAdd a b = (a + b) % q

modSub : [16] -> [16] -> [16]
modSub a b = (a + q - b) % q

modMul : [16] -> [16] -> [16]
modMul a b = (a * b) % q

// Inverse NTT butterfly: (a, b) -> (a+b, zeta*(b-a))
butterfly : [16] -> ([16], [16]) -> ([16], [16])
butterfly zeta (a, b) = (modAdd a b, modMul zeta (modSub b a))

// Update polynomial at two positions
updatePair : [256][16] -> [8] -> [8] -> [16] -> [16] -> [256][16]
updatePair f j len a b = [ if k == j then a else if k == (j + len) then b else f @ k | k <- [0 .. 255] ]

// Process one block: apply butterflies to all pairs in block
processBlock : [128][16] -> [7] -> [256][16] -> [8] -> [8] -> ([7], [256][16])
processBlock zetas i f start len = (i - (fromInteger blockCount), f')
  where
    blockCount : Integer
    blockCount = toInteger {8} len
    f' = f // UNRESOLVED: iterate over j in [start .. start+len-1], applying butterflies

// Process one stage: apply all blocks of given length
processStage : [128][16] -> [7] -> [256][16] -> [8] -> ([7], [256][16])
processStage zetas i f len = (i', f')
  where
    // 256/(2*len) blocks per stage
    i' = i - fromInteger (128 / toInteger {8} len)
    f' = f // UNRESOLVED: fold over blocks

// Inverse NTT
// zetas: 128 twiddle factors (zeta^BitRev7(i) for i=0..127)
// f_hat: polynomial in NTT representation
// Returns: polynomial in normal domain
NTT_inverse : [128][16] -> [256][16] -> [256][16]
NTT_inverse zetas f_hat = final
  where
    // Stages: len = 2, 4, 8, 16, 32, 64, 128
    // i starts at 127, decrements with each block across all stages
    // After all stages, multiply by scale factor
    
    // UNRESOLVED: Complete staged fold processing
    // Structure: foldl over stages [2,4,8,16,32,64,128]
    // Each stage processes 256/(2*len) blocks
    // Each block uses one zeta value, decrements i
    
    final = [ modMul x scale | x <- f_hat ]