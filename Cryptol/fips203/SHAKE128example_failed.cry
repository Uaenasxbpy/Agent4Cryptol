module SHAKE128example where

// SHAKE128 primitive operations (assumed defined in dependency module)
// type ShakeState represents the internal SHAKE128 state
// SHAKE128_Init : ShakeState
// SHAKE128_Absorb : {n} (fin n) => ShakeState -> [n][8] -> ShakeState
// SHAKE128_Squeeze : {k} (fin k) => ShakeState -> Integer -> (ShakeState, [k][8])

// ASSUMPTION: All input strings have uniform length n, all output segments have uniform length outLen
// Runtime-varying output lengths (b1, b_l as separate integers) cannot be expressed in executable Cryptol
// Total output length is l * outLen bytes at the type level

SHAKE128example :
    {m, n, l, outLen}
    (fin m, fin n, fin l, fin outLen) =>
    [m][n][8] -> [l][outLen][8]
SHAKE128example inputs = squeezeLoop l absorbedState
  where
    // Absorb all m input strings sequentially
    initState : ShakeState
    initState = SHAKE128_Init

    absorbedState : ShakeState
    absorbedState = foldl absorbStep initState inputs

    absorbStep : ShakeState -> [n][8] -> ShakeState
    absorbStep ctx str = SHAKE128_Absorb ctx str

    // Squeeze l output segments, threading state through each squeeze
    squeezeLoop :
        {j}
        (fin j, j <= l) =>
        ShakeState -> [j][outLen][8]
    squeezeLoop ctx =
        if `j == 0 then
            []
        else
            [out] # rest
          where
            (newCtx, out) = SHAKE128_Squeeze ctx (`outLen * 8)
            rest = squeezeLoop {j - 1} newCtx