module SamplePolyCBD_eta where

// Global modulus from FIPS203
q : Integer
q = 3329

SamplePolyCBD_eta : {eta} (fin eta, eta >= 1) => [64*eta][8] -> [256]Integer
SamplePolyCBD_eta B = f
  where
    bits : [512*eta]
    bits = join B

    f : [256]Integer
    f = [ (x - y) % q | i <- [0 .. 255] ]
      where
        baseIndex : Integer
        baseIndex = 2 * i * `eta

        x : Integer
        x = sum [ zext (bits @ (baseIndex + j)) | j <- [0 .. (eta - 1)] ]

        y : Integer
        y = sum [ zext (bits @ (baseIndex + `eta + j)) | j <- [0 .. (eta - 1)] ]