module NTT where

q : [12]
q = 3329

zetas : [128][12]
zetas = [1, 1729, 2580, 3289, 2642, 630, 1897, 848, 1062, 1919, 193, 797, 2786, 3260, 569, 1746, 296, 2447, 1339, 1476, 3046, 56, 2240, 1333, 1426, 2094, 535, 2882, 2393, 2879, 1974, 821, 289, 331, 3253, 1756, 1197, 2304, 2277, 2055, 650, 1977, 2513, 632, 2865, 33, 1320, 1915, 2319, 1435, 807, 452, 1438, 2868, 1534, 2402, 2647, 2617, 1481, 648, 2474, 3110, 1227, 910, 17, 2761, 583, 2649, 1637, 723, 2288, 1100, 1409, 2662, 3281, 233, 756, 2156, 3015, 3050, 1703, 1651, 2789, 1789, 1847, 952, 1461, 2687, 939, 2308, 2437, 2388, 733, 2337, 268, 641, 1584, 2298, 2037, 3220, 375, 2549, 2090, 1645, 1063, 319, 2773, 757, 2099, 561, 2466, 2594, 2804, 1092, 403, 1026, 1143, 2150, 2775, 886, 1722, 1212, 1874, 1029, 2110, 2935, 885, 2154]

BitRev7 : [8] -> [8]
BitRev7 i = zext (reverse (drop`{1} (i : [8])))

lens : [7][9]
lens = [128, 64, 32, 16, 8, 4, 2]

numBlocksList : [7][8]
numBlocksList = [1, 2, 4, 8, 16, 32, 64]

updates2 : [256][12] -> [2][9] -> [2][12] -> [256][12]
updates2 arr indices values = result
  where
    idx1 = indices @ 0
    idx2 = indices @ 1
    val1 = values @ 0
    val2 = values @ 1
    arr1 = arr // idx1 = val1
    result = arr1 // idx2 = val2

NTT : [256][12] -> [256][12]
NTT f = result
  where
    [result, _] = foldl processLayer [f, 1] [0..6]
    
    processLayer : ([256][12], [8]) -> [8] -> ([256][12], [8])
    processLayer state layer = foldl processBlock state blockStarts
      where
        [f_hat, zetaIdx] = state
        len = lens @ layer
        numBlocks = numBlocksList @ layer
        blockStarts = [2 * len * b | b <- take numBlocks [0 ...]]
        
        processBlock : ([256][12], [8]) -> [9] -> ([256][12], [8])
        processBlock [f_hat', zetaIdx'] start = [f_hat'', zetaIdx' + 1]
          where
            zeta = zetas @ (BitRev7 zetaIdx')
            f_hat'' = foldl butterfly f_hat' (take len [0 ...])
            
            butterfly : [256][12] -> [9] -> [256][12]
            butterfly f_hat'' j = updates2 f_hat'' [idx1, idx2] [f1, f2]
              where
                idx1 = start + j
                idx2 = start + j + len
                t = (zeta * f_hat'' @ idx2) % q
                f1 = (f_hat'' @ idx1 + t) % q
                f2 = (f_hat'' @ idx1 - t + q) % q