module SamplePolyCBD_eta where

// Global modulus from FIPS203
q : Integer
q = 3329

// eta resolved from active parameter set ML-KEM-512.
// Since the function name is SamplePolyCBD_eta and the caller context in ML-KEM-512
// may use either eta1=3 or eta2=2, but the input length is 64*eta,
// and the body uses eta as a fixed integer, we must pick one.
// However, the algorithm JSON does not specify which eta to use.
// Per parameter resolution notes: "eta may correspond to eta1 or eta2."
// Without explicit caller context, we cannot uniquely determine eta.
// But the input B has length 64*eta, so eta must be known at type level.
// Since the active parameter set provides both eta1 and eta2, and the function
// is generic over eta, we keep eta symbolic.

// However, note: the problem states "prefer encoding with concrete value if uniquely determined".
// Here it is NOT uniquely determined (could be eta1 or eta2), so we keep it symbolic.

// We assume eta is provided as a type-level parameter.
// Input B has length 64*eta bytes, so we require (64 * eta) bytes.

SamplePolyCBD_eta : {eta} (fin eta, eta >= 1) => [64*eta][8] -> [256]Integer
SamplePolyCBD_eta B = f
  where
    // Convert byte array to bit array: each byte becomes 8 bits, MSB first?
    // The algorithm says "BytesToBits(B)" — standard is big-endian per byte.
    // So bit index 0 is MSB of first byte.
    bits : [512*eta]
    bits = join B  // join : [n][8] -> [8*n]

    // For each coefficient i in [0..255]:
    f : [256]Integer
    f = [ (x - y) % q | i <- [0 .. 255] ]
      where
        baseIndex : Integer
        baseIndex = 2 * `i * `eta

        // Sum bits [baseIndex .. baseIndex + eta - 1]
        x : Integer
        x = sum [ zeroExtend bits@(baseIndex + j) | j <- take`{eta} [0 ...] ]

        // Sum bits [baseIndex + eta .. baseIndex + 2*eta - 1]
        y : Integer
        y = sum [ zeroExtend bits@(baseIndex + `eta + j) | j <- take`{eta} [0 ...] ]